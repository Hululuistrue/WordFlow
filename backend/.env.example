APP_NAME=yt-transcript-api
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
TEMP_DIR=./tmp
UPLOAD_STORAGE_DIR=./storage
ASR_MODEL_SIZE=base
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8
DATABASE_URL=sqlite:///./app.db
DATABASE_ECHO=false
DATABASE_AUTO_CREATE_TABLES=true
TASK_POLL_INTERVAL_SECONDS=2
SUBTITLE_FETCH_TIMEOUT_SECONDS=180
YTDLP_JS_RUNTIMES=node
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_COOKIES_FILE=
YTDLP_EXTRACTOR_ARGS=youtube:player_client=android,web
YTDLP_REMOTE_COMPONENTS=ejs:github
ALLOW_USER_SUPPLIED_COOKIES=false
YOUTUBE_COOKIES_MAX_CHARS=200000
